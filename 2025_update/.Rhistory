value <- redfin_raw %>%
filter(str_detect(REGION, metro_area)) %>%
transmute(
date = PERIOD_BEGIN,
region = REGION,
property_type = PROPERTY_TYPE,
median_sale_price = MEDIAN_SALE_PRICE,
seasonally_adjusted = IS_SEASONALLY_ADJUSTED)
